{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.dev)",
      "Read(./.env.production)",
      "Read(./.env.prod)",
      "Read(./.env.staging)",
      "Read(./.env.test)",
      "Read(./.env.ci)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.production)",
      "Read(./**/.env.staging)",
      "Read(./.envrc)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./**/credentials.json)",
      "Read(./**/credentials.yaml)",
      "Read(./**/credentials.yml)",
      "Read(./**/credentials.toml)",
      "Read(./**/service-account*.json)",
      "Read(./**/application_default_credentials.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.pfx)",
      "Read(./**/*.p12)",
      "Read(./**/*.tfvars)",
      "Read(./**/*.tfstate)",
      "Read(./**/*.tfstate.backup)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.oci/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/**)",
      "Read(~/.cloudflared/**)",
      "Read(~/.heroku/**)",
      "Read(~/.vercel/**)",
      "Read(~/.netlify/**)",
      "Read(~/.firebase/**)",
      "Read(~/.vault-token)",
      "Read(~/.config/op/**)",
      "Read(~/.password-store/**)",
      "Read(~/.git-credentials)",
      "Read(~/.config/git/credentials)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/.cargo/credentials)",
      "Read(~/.cargo/credentials.toml)",
      "Read(~/.m2/settings.xml)",
      "Read(~/.bundle/config)",
      "Read(~/.pgpass)",
      "Read(~/.my.cnf)",
      "Read(~/.zsh_history)",
      "Read(~/.bash_history)",
      "Read(~/.sh_history)",
      "Read(~/.fish_history)",
      "Read(~/.python_history)",
      "Read(~/.node_repl_history)",
      "Read(~/.irb_history)",
      "Read(~/.psql_history)",
      "Read(~/.mysql_history)",
      "Read(~/.sqlite_history)",
      "Read(~/.mongorc.js)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "./.env",
        "./.env.*",
        "./.envrc",
        "./secrets",
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.azure",
        "~/.oci",
        "~/.config/gcloud",
        "~/.kube",
        "~/.docker",
        "~/.cloudflared",
        "~/.heroku",
        "~/.vercel",
        "~/.netlify",
        "~/.firebase",
        "~/.vault-token",
        "~/.config/op",
        "~/.password-store",
        "~/.git-credentials",
        "~/.config/git/credentials",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.gem/credentials",
        "~/.cargo/credentials",
        "~/.cargo/credentials.toml",
        "~/.m2/settings.xml",
        "~/.bundle/config",
        "~/.pgpass",
        "~/.my.cnf",
        "~/.zsh_history",
        "~/.bash_history",
        "~/.sh_history",
        "~/.fish_history",
        "~/.python_history",
        "~/.node_repl_history",
        "~/.irb_history",
        "~/.psql_history",
        "~/.mysql_history",
        "~/.sqlite_history",
        "~/.mongorc.js"
      ],
      "allowRead": [
        "./.env.example",
        "./.env.sample",
        "./.env.template",
        "./.env.dist"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-openai-api-key.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-secrets.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-config-delete.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-config-edit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-end-dotnet-build.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
