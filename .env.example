# Copy this file to `.env` (which is gitignored) and fill in real values before running `docker compose up`.
# `.env` is loaded automatically by Docker Compose.

# --- Postgres ---
POSTGRES_DB=traffic_monitor
POSTGRES_USER=traffic
POSTGRES_PASSWORD=change-me-in-env

# --- API connection string ---
# Consumed by the API when you run it locally (`dotnet run` or VS Code F5).
# When the API runs inside Docker Compose, `docker-compose.yml` overrides this
# with Host=postgres. Keep the password here in sync with POSTGRES_PASSWORD above.
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=traffic_monitor;Username=traffic;Password=change-me-in-env
